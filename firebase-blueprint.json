{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique ID from Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "currency": { "type": "string", "enum": ["INR", "USD", "EUR"], "description": "User's preferred currency" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An income or expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the transaction" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "source": { "type": "string", "description": "Source for income" },
        "paymentMethod": { "type": "string" },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All income and expense records"
    }
  }
}
